# SocraticTeach-Env Configuration
# Copy this file to .env and fill in the values

# API Configuration
# The base URL for the LLM API (if using external LLM)
API_BASE_URL=http://localhost:8000

# Model Configuration
# The model identifier to use for inference
MODEL_NAME=default-teacher

# HuggingFace Configuration
# Your HuggingFace API token (optional, but recommended for HF integration)
HF_TOKEN=

# Inference Configuration
# Number of episodes to run (default: 3)
NUM_EPISODES=3
